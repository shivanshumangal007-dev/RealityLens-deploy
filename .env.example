# RealityLens Configuration Template
# Copy this file to .env and fill in your credentials

# ── AI / Search APIs ──────────────────────────────────────────────────────────

# Groq API Key (https://console.groq.com)
GROQ_API_KEY=

# Google Gemini API Keys (comma-separated for fallback)
GEMINI_API_KEYS=

# Tavily Search API Key (https://tavily.com)
TAVILY_API_KEY=

# Cloudflare Kimi API (optional)
CLOUDFLARE_AUTH_TOKEN=
ACCOUNT_ID=

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection (required for production)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://realitylens:password@localhost:5432/realitylens

# ── Server Configuration ──────────────────────────────────────────────────────

# Deployed server URL (used by desktop client)
DEPLOYED_SERVER_URL=http://localhost:8000

# For production, use https:// and your domain
# DEPLOYED_SERVER_URL=https://api.realitylens.example.com
